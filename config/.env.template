# Elite Trading Bot - Secure Configuration Template
# Copy this file to .env and fill in your credentials
# NEVER commit .env to version control!

# MetaTrader 5 Account Credentials
# CRITICAL SECURITY: Never commit .env file to version control!
# CRITICAL SECURITY: Never use demo credentials in production!
# CRITICAL SECURITY: Change these values immediately after copying this file!
MT5_LOGIN=YOUR_MT5_LOGIN_HERE
MT5_PASSWORD=YOUR_SECURE_PASSWORD_HERE
MT5_INVESTOR=YOUR_INVESTOR_PASSWORD_HERE
MT5_SERVER=YOUR_BROKER_SERVER_HERE

# SECURITY WARNING: Replace ALL placeholder values above with your actual credentials
# These credentials provide full access to your trading account
# Treat them with the same security as your bank account credentials

# Email Notifications
# SECURITY: Remove or replace with placeholder before committing
EMAIL_ADDRESS=your_email@example.com
SMTP_SERVER=smtp.example.com
SMTP_PORT=587
SMTP_USERNAME=your_smtp_username
SMTP_PASSWORD=your_secure_smtp_password

# Get Outlook app password from:
# https://account.microsoft.com/security
# Enable 2FA, then create app password

# Risk Management Limits
MAX_DAILY_LOSS=100
MAX_POSITION_SIZE=0.01
MAX_POSITIONS=3

# Trading Mode
PAPER_TRADING=true

# Cloud Deployment
CLOUD_PROVIDER=aws
REGION=us-east-1
HEALTH_CHECK_PORT=8080

# IBM Quantum API Key
IBM_QUANTUM_API_KEY=your_ibm_quantum_api_key_here
